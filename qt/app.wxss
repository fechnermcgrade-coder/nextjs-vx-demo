page {
  min-height: 100vh;
  background: #f6f3ec;
  color: #1f2933;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

button {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border: 0;
  line-height: normal;
}

button::after {
  border: 0;
}

.safe-page {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.muted {
  color: #667085;
}

.card-shadow {
  box-shadow: 0 8rpx 26rpx rgba(90, 42, 24, 0.08);
}

.login-guard {
  margin-top: 24rpx;
  padding: 54rpx 36rpx;
  border-radius: 36rpx;
  background: linear-gradient(145deg, #fbfaf6 0%, #eef4f3 100%);
  text-align: center;
}

.login-guard-title {
  color: #1f2933;
  font-size: 40rpx;
  font-weight: 900;
}

.login-guard-text {
  margin-top: 16rpx;
  color: #789195;
  font-size: 26rpx;
  line-height: 1.65;
}

.login-guard-btn {
  width: 260rpx;
  height: 80rpx;
  margin: 34rpx auto 0;
  border-radius: 999rpx;
  background: #2f5d62;
  color: #fff;
  font-size: 28rpx;
  font-weight: 900;
}

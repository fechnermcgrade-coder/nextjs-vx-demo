.page {
  min-height: 100vh;
  padding: 32rpx;
  padding-bottom: 164rpx;
  box-sizing: border-box;
}

.messages {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.message {
  width: 100%;
  padding: 26rpx;
  border: 1rpx solid #d8e1e8;
  border-radius: 12rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.message-name {
  color: #17202a;
  font-size: 30rpx;
  font-weight: 900;
}

.message-content {
  margin-top: 8rpx;
  color: #17202a;
  font-size: 28rpx;
  line-height: 1.6;
}

.composer {
  position: fixed;
  right: 0;
  bottom: 32rpx;
  left: 0;
  display: flex;
  gap: 10rpx;
  margin: 0 32rpx;
  padding: 18rpx;
  border: 1rpx solid #d8e1e8;
  border-radius: 24rpx;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow: 0 8rpx 26rpx rgba(90, 42, 24, 0.08);
}

.input {
  min-width: 0;
  flex: 1;
  height: 76rpx;
  padding: 0 22rpx;
  border: 1rpx solid #d8e1e8;
  border-radius: 16rpx;
  background: #fbfdfc;
  font-size: 28rpx;
}

.send {
  width: 116rpx !important;
  min-width: 0 !important;
  height: 72rpx;
  padding: 0 !important;
  border-radius: 14rpx;
  background: #2f5d62;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
}

.empty {
  padding: 64rpx 0;
  color: #667085;
  font-size: 28rpx;
  text-align: center;
}

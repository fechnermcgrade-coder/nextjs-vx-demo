<view class="page">
  <view wx:if="{{needLogin}}" class="login-guard card-shadow">
    <view class="login-guard-title">请先登录</view>
    <view class="login-guard-text">消息、会话和 AI 助手需要登录后使用。</view>
    <button class="login-guard-btn" bindtap="goLogin">去登录</button>
  </view>

  <block wx:else>
    <view class="header">
      <view class="title">消息</view>
      <view class="subtitle">查看和其他用户的会话</view>
    </view>

    <view class="ai-card card-shadow">
      <view class="ai-head">
        <view>
          <view class="ai-title">AI 助手</view>
          <view class="ai-subtitle">检索社区内容，帮你整理回复和想法</view>
        </view>
      </view>
      <scroll-view class="ai-messages" scroll-y>
        <view wx:for="{{aiMessages}}" wx:key="createdAt" class="ai-row {{item.role}}">
          <view class="ai-bubble">{{item.content}}</view>
        </view>
        <view wx:if="{{aiSending}}" class="ai-loading">AI 正在回复...</view>
      </scroll-view>
      <view class="ai-composer">
        <input class="ai-input" value="{{aiInput}}" bindinput="onAiInput" placeholder="问文章、收藏、历史或回复措辞" confirm-type="send" bindconfirm="sendAi" />
        <button class="ai-send" loading="{{aiSending}}" disabled="{{aiSending}}" bindtap="sendAi">发送</button>
      </view>
    </view>

    <view class="section-title">会话列表</view>
    <view wx:if="{{loading}}" class="empty">消息加载中...</view>
    <view wx:elif="{{threads.length === 0}}" class="empty">暂无会话</view>
    <view wx:else class="list">
      <view wx:for="{{threads}}" wx:key="peerId" class="thread" data-id="{{item.peerId}}" data-name="{{item.peerName}}" bindtap="openChat">
        <view class="thread-main">
          <view class="thread-name">{{item.peerName}}</view>
          <view class="thread-last">{{item.lastMessage}}</view>
        </view>
        <view wx:if="{{item.unreadCount}}" class="badge">{{item.unreadCount}}</view>
      </view>
    </view>
  </block>
</view>

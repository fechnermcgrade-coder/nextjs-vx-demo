.page { padding: 32rpx; }
.header { margin-bottom: 24rpx; }
.title { color: #17202a; font-size: 44rpx; font-weight: 900; }
.subtitle { margin-top: 8rpx; color: #667085; font-size: 26rpx; }
.ai-card { margin-bottom: 28rpx; padding: 26rpx; border-radius: 32rpx; background: #fff; }
.ai-head { display: flex; align-items: center; justify-content: space-between; }
.ai-title { color: #1f2933; font-size: 32rpx; font-weight: 900; }
.ai-subtitle { margin-top: 6rpx; color: #789195; font-size: 24rpx; }
.ai-messages { height: 360rpx; margin-top: 22rpx; padding: 18rpx; border-radius: 24rpx; background: #f8f3ef; box-sizing: border-box; overflow-y: auto; }
.ai-row { display: flex; margin-bottom: 16rpx; }
.ai-row.user { justify-content: flex-end; }
.ai-bubble { max-width: 82%; padding: 18rpx 22rpx; border-radius: 22rpx; background: #fff; color: #344054; font-size: 26rpx; line-height: 1.55; }
.ai-row.user .ai-bubble { background: #2f5d62; color: #fff; }
.ai-loading { color: #789195; font-size: 24rpx; font-weight: 800; }
.ai-composer { display: flex; gap: 14rpx; margin-top: 18rpx; }
.ai-input { min-width: 0; flex: 1; height: 76rpx; padding: 0 22rpx; border-radius: 18rpx; background: #f8f3ef; color: #1f2933; font-size: 26rpx; }
.ai-send { width: 116rpx !important; min-width: 0 !important; height: 72rpx; padding: 0 !important; border-radius: 14rpx; background: #2f5d62; color: #fff; font-size: 26rpx; font-weight: 900; line-height: 72rpx; }
.section-title { margin: 8rpx 0 18rpx; color: #1f2933; font-size: 32rpx; font-weight: 900; }
.list { display: flex; flex-direction: column; gap: 18rpx; }
.thread { display: flex; align-items: center; gap: 18rpx; padding: 26rpx; border: 1rpx solid #d8e1e8; border-radius: 18rpx; background: #ffffff; }
.thread-main { min-width: 0; flex: 1; }
.thread-name { color: #17202a; font-size: 30rpx; font-weight: 900; }
.thread-last { margin-top: 8rpx; color: #667085; font-size: 26rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.badge { min-width: 40rpx; height: 40rpx; padding: 0 10rpx; border-radius: 999rpx; background: #b42318; color: #ffffff; font-size: 22rpx; font-weight: 800; line-height: 40rpx; text-align: center; }
.empty { padding: 64rpx 0; color: #667085; font-size: 28rpx; text-align: center; }

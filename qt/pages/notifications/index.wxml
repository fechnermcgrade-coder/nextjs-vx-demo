<view class="page">
  <view class="header">
    <view class="header-main">
      <view class="title">通知</view>
      <view class="subtitle">系统消息、文章状态和互动提醒</view>
    </view>
    <button class="ghost-btn" bindtap="markRead">全部已读</button>
  </view>

  <view wx:if="{{loading}}" class="empty">通知加载中...</view>
  <view wx:elif="{{notifications.length === 0}}" class="empty">暂无通知</view>
  <view wx:else class="list">
    <view wx:for="{{notifications}}" wx:key="id" class="notice">
      <view class="notice-top">
        <view class="notice-title">{{item.title}}</view>
        <view wx:if="{{!item.readAt}}" class="dot"></view>
      </view>
      <view class="notice-content">{{item.content}}</view>
      <view class="notice-type">{{item.type}}</view>
    </view>
  </view>

  <view hidden="{{!confirmVisible}}" class="confirm-mask">
    <view class="confirm-card card-shadow">
      <view class="confirm-kicker">请确认</view>
      <view class="confirm-title">全部标记为已读？</view>
      <view class="confirm-text">确认后当前通知列表都会变成已读状态。</view>
      <view class="confirm-actions">
        <button class="confirm-cancel" bindtap="closeConfirm">取消</button>
        <button class="confirm-ok" bindtap="confirmMarkRead">确认</button>
      </view>
    </view>
  </view>
</view>

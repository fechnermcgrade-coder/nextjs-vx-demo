.page {
  padding: 32rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.header-main {
  min-width: 0;
  flex: 1;
}

.title {
  color: #17202a;
  font-size: 44rpx;
  font-weight: 900;
}

.subtitle {
  margin-top: 8rpx;
  color: #667085;
  font-size: 26rpx;
}

.ghost-btn {
  width: 124rpx !important;
  min-width: 0 !important;
  flex: 0 0 124rpx;
  height: 58rpx;
  padding: 0 !important;
  border: 1rpx solid #d8e1e8;
  border-radius: 999rpx;
  background: #eef4f3;
  color: #2f5d62;
  font-size: 22rpx;
  font-weight: 900;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.notice {
  padding: 26rpx;
  border: 1rpx solid #d8e1e8;
  border-radius: 12rpx;
  background: #ffffff;
}

.notice-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.notice-title {
  flex: 1;
  color: #17202a;
  font-size: 30rpx;
  font-weight: 900;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #b42318;
}

.notice-content {
  margin-top: 12rpx;
  color: #475467;
  font-size: 28rpx;
  line-height: 1.7;
}

.notice-type {
  margin-top: 16rpx;
  color: #24777b;
  font-size: 24rpx;
  font-weight: 800;
}

.empty {
  padding: 64rpx 0;
  color: #667085;
  font-size: 28rpx;
  text-align: center;
}
.confirm-mask { position: fixed; inset: 0; z-index: 50; display: flex; align-items: center; justify-content: center; padding: 36rpx; background: rgba(31, 41, 51, 0.45); box-sizing: border-box; }
.confirm-card { width: 100%; max-width: 620rpx; padding: 36rpx; border-radius: 36rpx; background: #fff; box-sizing: border-box; }
.confirm-kicker { color: #b42318; font-size: 24rpx; font-weight: 900; }
.confirm-title { margin-top: 12rpx; color: #1f2933; font-size: 38rpx; font-weight: 900; }
.confirm-text { margin-top: 16rpx; color: #667085; font-size: 27rpx; line-height: 1.65; }
.confirm-actions { display: flex; margin-top: 34rpx; }
.confirm-cancel, .confirm-ok { min-width: 0; height: 76rpx; flex: 1; border-radius: 999rpx; font-size: 27rpx; font-weight: 900; }
.confirm-cancel { margin-right: 18rpx; background: #eef4f3; color: #2f5d62; }
.confirm-ok { background: #b42318; color: #fff; }

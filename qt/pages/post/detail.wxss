.page { padding: 32rpx; }
.status { display: flex; align-items: center; justify-content: center; min-height: 70vh; color: #999; font-size: 28rpx; }
.error { color: #9b2c2c; }
.article { display: flex; flex-direction: column; gap: 24rpx; }
.cover { width: 100%; height: 420rpx; border-radius: 34rpx; background: #eef4f3; box-shadow: 0 8rpx 26rpx rgba(90, 42, 24, 0.08); }
.meta, .comment-box, .content-card { padding: 30rpx; border-radius: 34rpx; background: #fff; box-shadow: 0 8rpx 26rpx rgba(90, 42, 24, 0.08); }
.meta { color: #2f5d62; font-size: 25rpx; font-weight: 900; }
.title { padding: 0 6rpx; color: #1f2933; font-size: 48rpx; font-weight: 900; line-height: 1.25; }
.tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.tag { padding: 8rpx 18rpx; border-radius: 999rpx; background: #e8efed; color: #2f5d62; font-size: 24rpx; font-weight: 800; }
.article-actions { display: flex; gap: 18rpx; }
.favorite-btn, .ai-recommend-btn, .chat-author-btn { min-width: 0; flex: 1; height: 82rpx; border-radius: 999rpx; font-size: 28rpx; font-weight: 900; line-height: 82rpx; }
.favorite-btn { background: #fff3d6; color: #8a5a00; }
.favorite-btn.active { background: #2f5d62; color: #fff; }
.ai-recommend-btn { background: #e8f1ff; color: #1d5f91; }
.chat-author-btn { background: #1f2933; color: #fff; }
.ai-card { padding: 28rpx; border-radius: 30rpx; background: #fff; box-shadow: 0 8rpx 26rpx rgba(90, 42, 24, 0.08); }
.ai-card-head { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; }
.ai-title { color: #1f2933; font-size: 30rpx; font-weight: 900; }
.ai-score { flex: none; padding: 8rpx 18rpx; border-radius: 999rpx; background: #eef4f3; color: #2f5d62; font-size: 24rpx; font-weight: 900; }
.ai-text { margin-top: 18rpx; color: #344054; font-size: 27rpx; line-height: 1.7; }
.ai-note { margin-top: 16rpx; color: #789195; font-size: 23rpx; line-height: 1.55; }
.content { padding: 32rpx; border-radius: 34rpx; background: #fff; color: #344054; font-size: 30rpx; line-height: 1.85; box-shadow: 0 8rpx 26rpx rgba(90, 42, 24, 0.08); }
.section-title { color: #1f2933; font-size: 34rpx; font-weight: 900; }
.comment-input { width: 100%; min-height: 160rpx; margin-top: 20rpx; padding: 22rpx; border-radius: 24rpx; box-sizing: border-box; background: #f8f3ef; font-size: 28rpx; }
.comment-submit { height: 82rpx; margin-top: 18rpx; border-radius: 999rpx; background: #2f5d62; color: #fff; font-size: 28rpx; font-weight: 900; line-height: 82rpx; }
.comment-item { margin-top: 24rpx; padding: 24rpx; border-radius: 24rpx; background: #fdf9f5; }
.comment-meta { color: #2f5d62; font-size: 24rpx; font-weight: 900; }
.comment-content { margin-top: 8rpx; color: #344054; font-size: 27rpx; line-height: 1.6; }
.empty { padding: 54rpx 0; color: #aaa; text-align: center; }
.confirm-mask { position: fixed; inset: 0; z-index: 50; display: flex; align-items: center; justify-content: center; padding: 36rpx; background: rgba(31, 41, 51, 0.45); box-sizing: border-box; }
.confirm-card { width: 100%; max-width: 620rpx; padding: 36rpx; border-radius: 36rpx; background: #fff; box-sizing: border-box; }
.confirm-kicker { color: #b42318; font-size: 24rpx; font-weight: 900; }
.confirm-title { margin-top: 12rpx; color: #1f2933; font-size: 38rpx; font-weight: 900; }
.confirm-text { margin-top: 16rpx; color: #667085; font-size: 27rpx; line-height: 1.65; }
.confirm-actions { display: flex; margin-top: 34rpx; }
.confirm-cancel, .confirm-ok { min-width: 0; height: 76rpx; flex: 1; border-radius: 999rpx; font-size: 27rpx; font-weight: 900; }
.confirm-cancel { margin-right: 18rpx; background: #eef4f3; color: #2f5d62; }
.confirm-ok { background: #b42318; color: #fff; }

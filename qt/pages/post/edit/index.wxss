.page { padding: 32rpx; }
.header, .form { border-radius: 38rpx; background: #fff; box-shadow: 0 8rpx 26rpx rgba(90, 42, 24, 0.08); }
.header { padding: 34rpx; margin-bottom: 24rpx; background: linear-gradient(145deg, #fbfaf6 0%, #eef4f3 100%); }
.eyebrow { color: #2f5d62; font-size: 24rpx; font-weight: 900; letter-spacing: 2rpx; }
.title { margin-top: 10rpx; color: #1f2933; font-size: 44rpx; font-weight: 900; }
.hint { margin-top: 14rpx; color: #789195; font-size: 26rpx; line-height: 1.65; }
.form { padding: 34rpx; }
.label { margin-top: 28rpx; color: #1f2933; font-size: 26rpx; font-weight: 900; }
.label:first-child { margin-top: 0; }
.input, .textarea { width: 100%; margin-top: 12rpx; padding: 0 22rpx; border-radius: 24rpx; box-sizing: border-box; background: #f8f3ef; color: #1f2933; font-size: 28rpx; }
.input { height: 86rpx; line-height: 86rpx; }
.textarea { padding: 22rpx; }
.textarea { min-height: 420rpx; line-height: 1.7; }
.category-picker { display: flex; align-items: center; justify-content: space-between; min-height: 92rpx; margin-top: 12rpx; padding: 18rpx 22rpx; border-radius: 24rpx; background: #eef4f3; box-sizing: border-box; }
.category-picker.disabled { opacity: 0.65; }
.category-main { min-width: 0; }
.category-name { color: #1f2933; font-size: 28rpx; font-weight: 900; }
.category-hint { margin-top: 6rpx; color: #789195; font-size: 23rpx; }
.category-arrow { flex: 0 0 auto; color: #2f5d62; font-size: 44rpx; font-weight: 900; line-height: 1; }
.cover-picker { position: relative; display: flex; align-items: center; justify-content: center; height: 360rpx; margin-top: 12rpx; overflow: hidden; border-radius: 28rpx; background: #eef4f3; color: #2f5d62; font-size: 28rpx; font-weight: 900; }
.cover-image { width: 100%; height: 100%; }
.cover-empty { padding: 24rpx; }
.cover-mask { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(31, 41, 51, 0.45); color: #fff; font-size: 28rpx; font-weight: 900; }
.remove-cover { height: 72rpx; margin-top: 16rpx; border-radius: 999rpx; background: #fff3d6; color: #8a5a00; font-size: 26rpx; font-weight: 900; }
.actions { display: flex; width: 100%; margin-top: 30rpx; box-sizing: border-box; }
.ai, .submit, .draft { min-width: 0; height: 76rpx; flex: 1; border-radius: 999rpx; color: #fff; font-size: 25rpx; font-weight: 900; box-sizing: border-box; }
.ai, .draft { margin-right: 22rpx; }
.ai { background: #c9a66b; color: #1f2933; }
.submit { background: linear-gradient(135deg, #2f5d62, #4f7f84); }
.draft { background: #1f2933; }
.confirm-mask { position: fixed; inset: 0; z-index: 50; display: flex; align-items: center; justify-content: center; padding: 36rpx; background: rgba(31, 41, 51, 0.45); box-sizing: border-box; }
.confirm-card { width: 100%; max-width: 620rpx; padding: 36rpx; border-radius: 36rpx; background: #fff; box-sizing: border-box; }
.confirm-kicker { color: #b42318; font-size: 24rpx; font-weight: 900; }
.confirm-kicker.danger { color: #b42318; }
.confirm-title { margin-top: 12rpx; color: #1f2933; font-size: 38rpx; font-weight: 900; }
.confirm-text { margin-top: 16rpx; color: #667085; font-size: 27rpx; line-height: 1.65; }
.confirm-actions { display: flex; margin-top: 34rpx; }
.confirm-cancel, .confirm-ok { min-width: 0; height: 76rpx; flex: 1; border-radius: 999rpx; font-size: 27rpx; font-weight: 900; }
.confirm-cancel { margin-right: 18rpx; background: #eef4f3; color: #2f5d62; }
.confirm-ok { background: #b42318; color: #fff; }
.confirm-ok.danger-bg { background: #b42318; }

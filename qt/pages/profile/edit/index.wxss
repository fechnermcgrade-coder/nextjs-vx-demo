.page { padding: 32rpx; }
.form { padding: 34rpx; border-radius: 38rpx; background: #fff; box-shadow: 0 8rpx 26rpx rgba(90, 42, 24, 0.08); }
.avatar-field { display: flex; align-items: center; gap: 24rpx; margin-bottom: 8rpx; }
.avatar-wrap { position: relative; width: 132rpx; height: 132rpx; overflow: hidden; border-radius: 44rpx; background: #eef4f3; }
.avatar { display: flex; align-items: center; justify-content: center; width: 132rpx; height: 132rpx; color: #2f5d62; font-size: 54rpx; font-weight: 900; }
.avatar-image { width: 132rpx; height: 132rpx; }
.avatar-mask { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(31, 41, 51, 0.46); color: #fff; font-size: 22rpx; font-weight: 900; }
.avatar-btn { width: 210rpx; height: 76rpx; margin: 0; border-radius: 999rpx; background: #eef4f3; color: #2f5d62; font-size: 26rpx; font-weight: 900; line-height: 76rpx; }
.label { margin-top: 28rpx; color: #1f2933; font-size: 26rpx; font-weight: 900; }
.input, .textarea { width: 100%; margin-top: 12rpx; padding: 22rpx; border-radius: 24rpx; box-sizing: border-box; background: #f8f3ef; color: #1f2933; font-size: 28rpx; }
.input { height: 86rpx; padding: 0 22rpx; line-height: 86rpx; }
.textarea { min-height: 180rpx; line-height: 1.7; }
.submit { width: 100%; height: 82rpx; margin-top: 30rpx; border-radius: 999rpx; background: linear-gradient(135deg, #2f5d62, #4f7f84); color: #fff; font-size: 28rpx; font-weight: 900; line-height: 82rpx; }
